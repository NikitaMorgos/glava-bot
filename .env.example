# ===========================================
# Пример переменных окружения
# Скопируй этот файл как .env и заполни своими значениями
# ===========================================

# Токен бота от @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Строка подключения к PostgreSQL
# Формат: postgresql://пользователь:пароль@хост:порт/имя_базы
DATABASE_URL=postgresql://postgres:password@localhost:5432/glava_bot

# S3-совместимое хранилище (AWS S3, MinIO, Yandex Object Storage и т.д.)
S3_ENDPOINT_URL=https://s3.amazonaws.com
# Для MinIO: http://localhost:9000
# Для Yandex: https://storage.yandexcloud.net

S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=glava-voice-messages

# Регион (для AWS S3 — например us-east-1; для MinIO можно оставить пустым)
S3_REGION=us-east-1

# Транскрибация через Yandex SpeechKit (опционально)
# Создай API-ключ: Сервисные аккаунты → glava-bot → Создать API-ключ
YANDEX_API_KEY=

# Личный кабинет (cabinet.glava.family)
CABINET_SECRET_KEY=random-secret-for-sessions-change-in-prod

# Пароль для входа в раздел /admin/prompts (управление промптами пайплайна)
# Установи сложный пароль в production!
ADMIN_PASSWORD=change-me-in-production
TRUST_PROXY=1

# Диаризация — по умолчанию работает через Resemblyzer (без регистрации).
# Для pyannote (точнее): создай токен на hf.co/settings/tokens, прими условия моделей
# HUGGINGFACE_TOKEN=

# Транскрибер: recall | mymeet | plaud | assemblyai | speechkit
# Если не задан — приоритет: recall → plaud → mymeet → assemblyai → speechkit/whisper
TRANSCRIBER=recall

# AssemblyAI — транскрипция (dashboard.assemblyai.com)
ASSEMBLYAI_API_KEY=

# mymeet.ai — транскрипция (B2B, ключ: mymeet.ai/contact)
MYMEET_API_KEY=
# Ссылка на встречу Телемост (или другую) для выдачи по кнопке «Получить ссылку» в /online
# TELEMOST_MEETING_LINK=

# Meeting bot — основной способ записи онлайн-встреч (Playwright + Chromium, Linux + pulseaudio)
# При MEETING_BOT_ENABLED=true на Linux он выбирается раньше mymeet и Recall
# MEETING_BOT_ENABLED=true
# PulseAudio: systemd не передаёт XDG_RUNTIME_DIR — без этих строк pactl выдаёт "Access denied"
# XDG_RUNTIME_DIR=/run/user/0
# PULSE_SERVER=unix:/run/user/0/pulse/native
# Отладка входа (скриншот + список input в лог): MEETING_JOIN_DEBUG=true
# MEETING_JOIN_DEBUG=

# Recall.ai — опционально, если не используете meeting_bot и mymeet (Telemost не поддерживается)
# Ключ: https://www.recall.ai/ → Settings → API Keys
# Транскрипция через AssemblyAI (поддерживает русский язык)
RECALL_API_KEY=
# Регион: us-east-1 (по умолчанию), eu-west-2, us-west-2
# RECALL_REGION=us-east-1

# Plaud AI — транскрипция с диаризацией (docs.plaud.ai)
PLAUD_API_TOKEN=
PLAUD_OWNER_ID=glava_default

# OpenAI — обработка транскрипта в биографию для семейной книги
OPENAI_API_KEY=
# Модель для bio: gpt-4o (рекомендуется), gpt-4-turbo, gpt-4. Не использовать gpt-4o-mini для качественной биографии
# OPENAI_BIO_MODEL=gpt-4o

# Anthropic Claude — верстальщик PDF (ключ: console.anthropic.com)
ANTHROPIC_API_KEY=

# ЮKassa — приём платежей (yookassa.ru → Магазины → shop_id, secret_key)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Куда вернуть пользователя после оплаты
# PAYMENT_RETURN_URL=https://t.me/glava_voice_bot

# ===========================================
# Admin Panel (admin.glava.family)
# ===========================================
# Секретный ключ сессий Flask (сгенерируй: python -c "import secrets; print(secrets.token_hex(32))")
ADMIN_SECRET_KEY=

# Пароли для входа в панель управления
ADMIN_PASSWORD_DEV=       # разработчик — полный доступ
ADMIN_PASSWORD_DASHA=     # продакт — скрипты, заказы
ADMIN_PASSWORD_LENA=      # маркетолог — рассылки

# n8n webhook URL (автоматически доступен после запуска Docker)
# После импорта workflow phase-a.json в n8n — путь будет /webhook/glava/phase-a
N8N_WEBHOOK_PHASE_A=http://localhost:5678/webhook/glava/phase-a
N8N_WEBHOOK_PHASE_B=http://localhost:5678/webhook/glava/phase-b

# Базовый URL admin API (для n8n, доступен с localhost сервера)
ADMIN_API_BASE_URL=http://127.0.0.1:5001/api

# Внутренний API-ключ (для доступа к /api/* с внешнего сервера, если нужно)
ADMIN_API_KEY=                    # ключ для /api/prompts/* (Cursor + Claude Code Даши)

# n8n базовая аутентификация редактора
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# SMSimple — SMS-рассылки (smsimple.ru → логин/пароль, подпись or_id в кабинете)
# SMSIMPLE_USER=
# SMSIMPLE_PASSWORD=
# SMSIMPLE_ORIGIN_ID=
# SMSIMPLE_BASE_URL=https://smsimple.ru
