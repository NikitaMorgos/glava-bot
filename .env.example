# ===========================================
# Пример переменных окружения
# Скопируй этот файл как .env и заполни своими значениями
# ===========================================

# Токен бота от @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Строка подключения к PostgreSQL
# Формат: postgresql://пользователь:пароль@хост:порт/имя_базы
DATABASE_URL=postgresql://postgres:password@localhost:5432/glava_bot

# S3-совместимое хранилище (AWS S3, MinIO, Yandex Object Storage и т.д.)
S3_ENDPOINT_URL=https://s3.amazonaws.com
# Для MinIO: http://localhost:9000
# Для Yandex: https://storage.yandexcloud.net

S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=glava-voice-messages

# Регион (для AWS S3 — например us-east-1; для MinIO можно оставить пустым)
S3_REGION=us-east-1

# Транскрибация через Yandex SpeechKit (опционально)
# Создай API-ключ: Сервисные аккаунты → glava-bot → Создать API-ключ
YANDEX_API_KEY=

# Диаризация — по умолчанию работает через Resemblyzer (без регистрации).
# Для pyannote (точнее): создай токен на hf.co/settings/tokens, прими условия моделей
# HUGGINGFACE_TOKEN=
