    {
      "page_number": 4,
      "type": "chapter_start",
      "chapter_id": "ch_01",
      "chapter_number": "01",
      "chapter_title": "Основные даты жизни",
      "chapter_subtitle": "Мариевка · 1920–2005",
      "elements": [
        {
          "type": "bio_data_block",
          "content": "Каракулина Валентина Ивановна.\nРодилась 1920 в село Мариевка, Новомиргородский район, Кировоградская область."
        }
      ]
    },
    {
      "page_number": 5,
      "type": "bio_timeline",
      "chapter_id": "ch_01",
      "elements": [
        {
