        {
          "type": "callout",
          "callout_id": "callout_01",
          "text": "Она была как муравей, а не стрекоза из известной басни — всю жизнь трудилась, всё время что-то делала, не умела сидеть без дела",
          "rationale": "Callout о трудолюбии размещён в разделе о характере"
        }
